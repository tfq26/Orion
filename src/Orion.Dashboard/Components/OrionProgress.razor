<div class="flex flex-col gap-1 w-full @Class">
@if (!HideLabel)
{
    <div class="flex justify-between items-baseline text-sm">
        <span class="text-secondary font-medium">@Label</span>
        <span class="font-mono text-primary font-medium">@ValueLabel</span>
    </div>
}
    <div class="h-1 bg-surface rounded-full overflow-hidden relative border border-white/5">
        <div class="h-full rounded-full transition-all duration-700 ease-out @GetColorClass()"
             style="width: @(Math.Clamp(Percentage, 0, 100))%"></div>
    </div>
</div>

@code {
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public string ValueLabel { get; set; } = "";
    [Parameter] public double Percentage { get; set; }
    [Parameter] public ProgressColor ColorPreset { get; set; } = ProgressColor.Auto;
    [Parameter] public string Class { get; set; } = "";
    [Parameter] public bool HideLabel { get; set; }

    public enum ProgressColor
    {
        Auto,
        Cyan,
        Purple
    }

    private string GetColorClass()
    {
        if (Percentage > 85) return "bg-error shadow-[0_0_10px_var(--error)]";
        if (Percentage > 65) return "bg-warning shadow-[0_0_10px_var(--warning)]";

        return ColorPreset switch
        {
            ProgressColor.Cyan => "bg-accent-cyan shadow-[0_0_10px_var(--accent-cyan)]",
            ProgressColor.Purple => "bg-accent-purple shadow-[0_0_10px_var(--accent-purple)]",
            _ => "bg-primary" // Fallback
        };
    }
}

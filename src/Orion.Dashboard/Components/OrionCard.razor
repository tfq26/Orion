<div class="bg-surface-elevated border border-border rounded-xl p-4 md:p-6 relative overflow-hidden transition-all duration-300 ease-out hover:border-border-light hover:shadow-[0_8px_30px_rgb(0,0,0,0.8)] @(Featured ? "after:absolute after:top-0 after:left-0 after:right-0 after:h-[1.5px] after:bg-accent-cyan shadow-[0_0_15px_rgba(0,230,243,0.05)]" : "") @Class"
     @attributes="InputAttributes">
    @ChildContent
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public bool Featured { get; set; }
    [Parameter] public string Class { get; set; } = "";
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object> InputAttributes { get; set; } = new();
}

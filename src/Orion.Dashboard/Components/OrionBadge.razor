<span class="@GetClasses()">
    @if (ShowDot)
    {
        <span class="w-2 h-2 rounded-full bg-current mr-2"></span>
    }
    @ChildContent
</span>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public BadgeVariant Variant { get; set; } = BadgeVariant.Default;
    [Parameter] public bool ShowDot { get; set; } = true;
    [Parameter] public string Class { get; set; } = "";

    public enum BadgeVariant
    {
        Default,
        Success,
        Warning,
        Error
    }

    private string GetClasses()
    {
        var baseClasses = "inline-flex items-center px-2.5 py-0.5 rounded-md text-[10px] font-bold uppercase tracking-wider border";
        
        var variantClasses = Variant switch
        {
            BadgeVariant.Default => "bg-surface-elevated text-secondary border-border",
            BadgeVariant.Success => "bg-success/5 text-success border-success/20",
            BadgeVariant.Warning => "bg-warning/5 text-warning border-warning/20",
            BadgeVariant.Error => "bg-error/5 text-error border-error/20",
            _ => ""
        };

        return $"{baseClasses} {variantClasses} {Class}";
    }
}

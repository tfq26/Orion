<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(App).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
                <NotAuthorized>
                    <LayoutView Layout="@typeof(MainLayout)">
                        <div class="h-screen w-full flex flex-col items-center justify-center bg-black text-white p-6">
                            <div class="text-4xl font-bold mb-8 text-white tracking-widest uppercase">Orion</div>
                            <div class="w-full max-w-md bg-[#0a0a0a] border border-[#161616] p-8 rounded-lg shadow-2xl">
                                <h2 class="text-2xl font-semibold mb-6 text-center">Session Required</h2>
                                <p class="text-gray-400 text-center mb-8">Please sign in with your enterprise account to access the dashboard.</p>
                                <a href="/auth/login" class="w-full block text-center bg-[#00e6f3] text-black font-bold py-3 px-4 rounded hover:bg-[#00c5d1] transition-all duration-300">
                                    Sign in with WorkOS
                                </a>
                            </div>
                        </div>
                    </LayoutView>
                </NotAuthorized>
                </AuthorizeRouteView>
                <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
        <NotFound>
            <PageTitle>Not found</PageTitle>
            <LayoutView Layout="@typeof(MainLayout)">
                <p role="alert">Sorry, there's nothing at this address.</p>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>

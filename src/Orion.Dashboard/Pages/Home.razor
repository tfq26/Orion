@page "/"
@inject HttpClient Http
@inject IJSRuntime JSRuntime
@using System.Threading
@using Microsoft.AspNetCore.Components.Authorization
@implements IDisposable

<PageTitle>Orion Base Control</PageTitle>

<div class="py-12 pl-12 pr-12 w-full">
    <header class="flex justify-between items-center mb-12 animate-[fadeInDown_0.8s_ease_forwards]">
        <div class="flex flex-col gap-1">
            <AuthorizeView>
                <Authorized>
                    <h1 class="text-3xl font-bold tracking-tight">Welcome back, @(context.User.Identity?.Name ?? "User")</h1>
                </Authorized>
                <NotAuthorized>
                    <h1 class="text-3xl font-bold tracking-tight">Welcome to Orion</h1>
                </NotAuthorized>
            </AuthorizeView>
            <p class="text-secondary text-sm">Cluster Status: Healthy • Orion Wormhole Active</p>
        </div>
    </header>

    @if (connectionErrors > 0 && summary == null)
    {
        <div class="flex flex-col items-center justify-center my-32 text-error">
            <div class="text-xl font-bold mb-2">Connection Error</div>
            <div class="text-sm opacity-80">Failed to connect to the Orion Control Plane API.</div>
            @if (fetchError != null)
            {
                <pre class="mt-4 text-xs text-left max-w-2xl overflow-auto p-4 bg-black/50 rounded-lg">@fetchError</pre>
            }
        </div>
    }
    else if (summary == null && connectionErrors == 0)
    {
        <div class="flex justify-center my-32">
            <div class="animate-pulse text-secondary tracking-widest uppercase text-sm">Synchronizing Control Plane...</div>
        </div>
    }
    else if (summary != null)
    {
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-16 opacity-0 animate-[fadeInUp_0.8s_ease_0.1s_forwards]">
            <OrionCard Featured="true" Class="!p-4">
                <div class="text-4xl font-light tracking-tight text-primary leading-none mb-2">@summary.TotalApps</div>
                <div class="text-xs font-medium text-secondary">Apps</div>
            </OrionCard>
            <OrionCard Featured="true" Class="!p-4">
                <div class="text-4xl font-light tracking-tight text-accent-cyan leading-none mb-2">@summary.ConnectedPeers</div>
                <div class="text-xs font-medium text-secondary">Active Nodes</div>
            </OrionCard>
            <OrionCard Class="!p-4">
                <div class="text-4xl font-light tracking-tight @(summary.PilotStatus == "Observing" ? "text-primary" : "text-error") leading-none mb-2 text-[0.9em]">@summary.PilotStatus</div>
                <div class="text-xs font-medium text-secondary">AI Pilot Status</div>
            </OrionCard>
            <OrionCard Featured="true" Class="!p-4">
                <div class="text-4xl font-light tracking-tight text-accent-purple leading-none mb-2 tracking-tighter">WORMHOLE</div>
                <div class="text-xs font-medium text-secondary">P2P Tunnel Active</div>
            </OrionCard>
        </div>

        <div class="flex justify-between items-end mb-8 opacity-0 animate-[fadeInUp_0.8s_ease_0.2s_forwards]">
            <h2 class="text-2xl font-semibold tracking-tight">Active Apps</h2>
        </div>

        <ErrorBoundary>
            <ChildContent>
        <div class="mb-8 opacity-0 animate-[fadeInUp_0.8s_ease_0.3s_forwards]">
            <table class="orion-table rounded-xl bg-surface">
                <thead>
                    <tr>
                        <th>App</th>
                        <th>Status</th>
                        <th>CPU Usage</th>
                        <th>Memory</th>
                        <th class="text-center">Instances</th>
                        <th class="w-10"></th>
                    </tr>
                </thead>
                <tbody>
                    @if(summary.Apps == null)
                    {
                       <tr><td colspan="6" class="text-error text-center p-8">summary.Apps is NULL!</td></tr>
                    }
                    else if(summary.Apps.Count == 0)
                    {
                       <tr><td colspan="6" class="text-secondary text-center p-8">No deployments found.</td></tr>
                    }
                    else
                    {
                        @foreach (var app in summary.Apps)
                        {
                            var isRunning = app.Status == "Running";
                            <tr class="hover:bg-surface-elevated/50 transition-colors">
                                <td>
                                    <div class="flex flex-col">
                                        <span class="font-bold text-primary">@app.Name</span>
                                        <span class="font-mono text-[10px] text-secondary/60 uppercase tracking-tighter font-medium">@app.Id.ToString().Substring(0, 12)</span>
                                    </div>
                                </td>
                                <td>
                                    <OrionBadge ShowDot="true" Variant="@(isRunning ? OrionBadge.BadgeVariant.Success : OrionBadge.BadgeVariant.Default)">
                                        @app.Status
                                    </OrionBadge>
                                </td>
                                <td class="min-w-[150px]">
                                    <OrionProgress Percentage="app.CpuUsage" 
                                                   ColorPreset="OrionProgress.ProgressColor.Cyan" 
                                                   HideLabel="true" />
                                    <div class="text-[10px] text-secondary mt-1 font-mono">@app.CpuUsage.ToString("F1")%</div>
                                </td>
                                <td>
                                    <div class="text-sm font-bold text-primary">@app.MemoryUsageMb<span class="text-[10px] text-secondary ml-1">MB</span></div>
                                </td>
                                <td class="text-center font-mono text-lg font-bold text-accent-cyan">@app.ActiveReplicas</td>
                                <td>
                                    <div class="orion-dropdown @(activeDropdownId == app.Id ? "show" : "")">
                                        <button @onclick="() => ToggleDropdown(app.Id)" @onclick:stopPropagation 
                                                class="p-2 hover:bg-surface-elevated rounded-md transition-colors text-secondary border border-transparent hover:border-border">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <circle cx="12" cy="12" r="1"/><circle cx="12" cy="5" r="1"/><circle cx="12" cy="19" r="1"/>
                                            </svg>
                                        </button>
                                        <div class="orion-dropdown-content @(activeDropdownId == app.Id ? "show" : "")">
                                            <a href="/apps/@app.Id" class="orion-dropdown-item">
                                                <svg width="14" height="14" class="mr-2 opacity-60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                                                View Details
                                            </a>
                                            <div class="orion-dropdown-item @(!isRunning ? "opacity-30 cursor-not-allowed" : "")" @onclick="@(async () => { if(isRunning) await OpenApp(app.Name); })">
                                                <svg width="14" height="14" class="mr-2 opacity-60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="9" y1="3" x2="9" y2="21"/></svg>
                                                Open Portal
                                            </div>
                                            <div class="orion-dropdown-item @(!isRunning ? "opacity-30 cursor-not-allowed" : "")" @onclick="@(async () => { if(isRunning) await ScaleApp(app.Id, app.ActiveReplicas + 1); })">
                                                <svg width="14" height="14" class="mr-2 opacity-60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                                                Add Instance (+)
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

            </ChildContent>
            <ErrorContent>
                <div class="bg-surface border border-error/50 p-8 rounded-xl my-8">
                    <h2 class="text-xl font-bold text-error mb-4">Rendering Crashed</h2>
                    <pre class="text-xs text-secondary max-w-full overflow-hidden">@context.Message</pre>
                    <pre class="text-xs text-secondary opacity-60 mt-4 overflow-hidden">@context.StackTrace</pre>
                </div>
            </ErrorContent>
        </ErrorBoundary>
    }
</div>

@code {
    private DashboardSummary? summary;
    private int connectionErrors = 0;
    private string? fetchError;
    private Guid? activeDropdownId;

    private static event Action? OnCloseAllDropdowns;

    [JSInvokable]
    public static void CloseAllDropdowns() => OnCloseAllDropdowns?.Invoke();

    private void ToggleDropdown(Guid id)
    {
        if (activeDropdownId == id) activeDropdownId = null;
        else activeDropdownId = id;
    }

    protected override void OnInitialized()
    {
        OnCloseAllDropdowns += HandleCloseAll;
    }

    private void HandleCloseAll()
    {
        if (activeDropdownId != null)
        {
            activeDropdownId = null;
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        OnCloseAllDropdowns -= HandleCloseAll;
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        _ = RunRefreshTimer();
    }

    private async Task RunRefreshTimer()
    {
        while (true)
        {
            await Task.Delay(3000);
            await LoadData();
            StateHasChanged();
        }
    }

    private async Task LoadData()
    {
        try
        {
            var result = await Http.GetFromJsonAsync("/dashboard/summary", Orion.Core.Serialization.OrionJsonContext.Default.DashboardSummary);
            if (result != null)
            {
                summary = result;
                connectionErrors = 0;
            }
        }
        catch (Exception ex)
        {
            fetchError = ex.ToString();
            connectionErrors++;
        }
    }

    private async Task ScaleApp(Guid id, int count)
    {
        try
        {
            await Http.PostAsync($"/apps/{id}/scale?replicas={count}", null);
            await LoadData();
        }
        catch
        {
        }
    }

    private async Task OpenApp(string name)
    {
        await JSRuntime.InvokeVoidAsync("open", $"http://{name.ToLower()}.lvh.me:5050", "_blank");
    }
}

@page "/infrastructure"
@inject HttpClient Http
@using Orion.Core.Models
@using Orion.Core.Serialization
@using Microsoft.JSInterop
@inject IJSRuntime JS

<div class="h-full w-full flex flex-col overflow-hidden bg-black text-white">
    @if (selectedApp == null)
    {
        <div class="flex-1 overflow-auto p-12">
            <header class="mb-12">
                <h1 class="text-3xl font-bold tracking-tight mb-2">Network Topology</h1>
                <p class="text-secondary">Select an Application to visualize its edge topology and Node distribution.</p>
            </header>

            @if (summary == null)
            {
                <div class="flex justify-center my-32">
                    <div class="animate-pulse text-secondary tracking-widest uppercase text-sm">Synchronizing Network State...</div>
                </div>
            }
            else
            {
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    @foreach (var app in summary.Apps)
                    {
                        <div class="group relative bg-surface border border-border rounded-xl p-6 hover:border-accent-cyan/50 transition-all cursor-pointer shadow-2xl overflow-hidden"
                             @onclick="() => SelectProject(app)">
                            <div class="absolute top-0 right-0 p-4 opacity-0 group-hover:opacity-100 transition-opacity">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent-cyan"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                            </div>
                            
                            <div class="flex flex-col gap-4">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 rounded-lg bg-accent-cyan/10 border border-accent-cyan/20 flex items-center justify-center">
                                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent-cyan"><rect width="16" height="16" x="4" y="4" rx="2"/><rect width="9" height="9" x="9" y="9" rx="2"/></svg>
                                    </div>
                                    <div>
                                        <h3 class="font-bold text-lg">@app.Name</h3>
                                        <div class="text-[10px] font-mono text-secondary uppercase tracking-widest">@app.Id.ToString().Substring(0, 8)</div>
                                    </div>
                                </div>

                                <div class="flex items-center gap-6 mt-2">
                                    <div class="flex flex-col">
                                        <span class="text-[10px] text-secondary uppercase font-bold tracking-widest opacity-50">Instances</span>
                                        <span class="text-xl font-mono text-primary">@app.ActiveReplicas</span>
                                    </div>
                                    <div class="flex flex-col">
                                        <span class="text-[10px] text-secondary uppercase font-bold tracking-widest opacity-50">Health</span>
                                        <span class="text-xl font-mono text-success">100%</span>
                                    </div>
                                    <div class="flex flex-col">
                                        <span class="text-[10px] text-secondary uppercase font-bold tracking-widest opacity-50">Region</span>
                                        <span class="text-xl font-mono text-accent-purple">GLOBAL</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    }
    else
    {
        <div class="p-2 border-b border-border bg-surface/30 backdrop-blur-sm z-10 flex justify-between items-center">
            <div class="flex items-center gap-4">
                <button @onclick="() => selectedApp = null" class="p-2 hover:bg-surface-elevated rounded-md transition-colors group">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-secondary group-hover:text-primary"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
                </button>
                <div class="flex flex-col">
                    <span class="text-xs font-bold text-primary">@selectedApp.Name</span>
                    <span class="text-[10px] text-secondary uppercase font-bold tracking-widest">Interactive Wormhole</span>
                </div>
            </div>
            <div class="flex gap-4 pr-4">
                <div class="flex items-center gap-2">
                    <div class="w-2 h-2 rounded-full bg-accent-cyan"></div>
                    <span class="text-[10px] text-secondary uppercase font-bold tracking-widest">Wormhole Edge</span>
                </div>
                <div class="flex items-center gap-2">
                    <div class="w-2 h-2 rounded-full bg-surface border border-border"></div>
                    <span class="text-[10px] text-secondary uppercase font-bold tracking-widest">Control Plane</span>
                </div>
            </div>
        </div>

        <div class="flex-1 relative overflow-auto select-none" 
             style="background-image: radial-gradient(circle at 1px 1px, #161616 1px, transparent 0); background-size: 40px 40px;"
             @onmousemove="OnMouseMove"
             @onmouseup="OnMouseUp">
            
            <svg class="absolute inset-0 w-[3000px] h-[3000px] pointer-events-none">
                <defs>
                    <linearGradient id="edgeGradient" x1="0%" y1="0%" x2="100%" y2="0%">
                        <stop offset="0%" style="stop-color:rgba(0,230,243,0.2);stop-opacity:1" />
                        <stop offset="100%" style="stop-color:rgba(0,230,243,0.05);stop-opacity:1" />
                    </linearGradient>
                </defs>

                @foreach (var edge in edges)
                {
                    <line x1="@edge.X1" y1="@edge.Y1" x2="@edge.X2" y2="@edge.Y2" 
                          stroke="url(#edgeGradient)" stroke-width="1.5" stroke-dasharray="4 4" class="transition-all duration-300">
                        <animate attributeName="stroke-dashoffset" from="0" to="-20" dur="2s" repeatCount="indefinite" />
                    </line>
                }
            </svg>

            <div class="relative w-[3000px] h-[3000px]">
                @foreach (var node in nodes)
                {
                    <div class="absolute p-px rounded-xl @(draggingNodeId == node.Id ? "z-50 cursor-grabbing" : "cursor-grab") transition-all @(selectedNodeId == node.Id ? "ring-2 ring-accent-cyan shadow-[0_0_30px_rgba(0,230,243,0.15)]" : "hover:border-accent-cyan/30")"
                         style="left: @(node.X)px; top: @(node.Y)px; transform: translate(-50%, -50%);"
                         @onmousedown="(e) => OnMouseDown(e, node.Id)"
                         @onclick="() => SelectNode(node.Id)"
                         @onclick:stopPropagation>
                        
                        <div class="bg-surface-elevated border border-border rounded-xl p-4 w-60 shadow-2xl">
                            <div class="flex items-center justify-between mb-3">
                                <div class="flex items-center gap-3">
                                    <div class="w-8 h-8 rounded-lg @(node.IsControlPlane ? "bg-surface" : "bg-accent-cyan/10") border border-border flex items-center justify-center">
                                        @if(node.IsControlPlane) {
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-secondary"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                                        } else {
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent-cyan"><rect width="16" height="16" x="4" y="4" rx="2"/><rect width="9" height="9" x="9" y="9" rx="2"/></svg>
                                        }
                                    </div>
                                    <span class="font-bold text-sm">@node.Name</span>
                                </div>
                                <div class="w-2 h-2 rounded-full @(node.Status == "Online" ? "bg-success shadow-[0_0_10px_rgba(52,213,154,0.4)]" : "bg-secondary")"></div>
                            </div>

                            <div class="grid grid-cols-2 gap-2 mt-4 pt-4 border-t border-white/5">
                                <div>
                                    <div class="text-[10px] text-secondary uppercase font-bold tracking-widest opacity-50">CPU</div>
                                    <div class="text-xs font-mono">@node.CpuUsage%</div>
                                </div>
                                <div>
                                    <div class="text-[10px] text-secondary uppercase font-bold tracking-widest opacity-50">Memory</div>
                                    <div class="text-xs font-mono">@node.MemoryUsage GB</div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    @if (selectedNodeId != null)
    {
        var node = nodes.FirstOrDefault(n => n.Id == selectedNodeId);
        @if (node != null)
        {
            <div class="absolute right-0 top-0 bottom-0 w-80 bg-surface border-l border-border z-20 shadow-[-10px_0_30px_rgba(0,0,0,0.5)] animate-[slideInRight_0.3s_ease_out]">
                <div class="p-6">
                    <div class="flex justify-between items-center mb-8">
                        <h2 class="text-lg font-bold">Node Properties</h2>
                        <button @onclick="() => selectedNodeId = null" class="p-2 hover:bg-surface-elevated rounded-md transition-colors">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                        </button>
                    </div>

                    <div class="flex flex-col gap-6">
                        <div class="p-4 bg-black/30 rounded-lg border border-white/5">
                            <div class="text-xs text-secondary mb-1">Hostname</div>
                            <div class="font-mono text-sm tracking-tight text-accent-cyan">@(node.Name.ToLower().Replace(" ", "-") + ".local")</div>
                        </div>

                        <div class="p-4 bg-black/30 rounded-lg border border-white/5">
                            <div class="text-xs text-secondary mb-1">Wormhole IP</div>
                            <div class="font-mono text-sm tracking-tight text-primary">10.0.0.@(node.Id.GetHashCode() % 255)</div>
                        </div>

                        <div class="p-4 bg-black/30 rounded-lg border border-white/5">
                            <div class="text-xs text-secondary mb-1">WASM Runtime</div>
                            <div class="text-sm">Wasmtime v22.0.1 (Native)</div>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>

<style>
    @@keyframes slideInRight {
        from { transform: translateX(100%); }
        to { transform: translateX(0); }
    }
    .cursor-grab { cursor: grab; }
    .cursor-grabbing { cursor: grabbing; }
</style>

@code {
    private DashboardSummary? summary;
    private AppSummary? selectedApp;
    private string? selectedNodeId;
    private string? draggingNodeId;
    private double startX, startY;
    private int nodeStartX, nodeStartY;

    public class Node {
        public string Id { get; set; } = "";
        public string Name { get; set; } = "";
        public bool IsControlPlane { get; set; }
        public int X { get; set; }
        public int Y { get; set; }
        public string Status { get; set; } = "Online";
        public int CpuUsage { get; set; }
        public double MemoryUsage { get; set; }
    }

    public class Edge {
        public int X1 { get; set; }
        public int Y1 { get; set; }
        public int X2 { get; set; }
        public int Y2 { get; set; }
    }

    private List<Node> nodes = new();
    private List<Edge> edges = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadSummary();
    }

    private async Task LoadSummary()
    {
        try
        {
            summary = await Http.GetFromJsonAsync("/dashboard/summary", OrionJsonContext.Default.DashboardSummary);
        }
        catch { }
    }

    private void SelectProject(AppSummary app)
    {
        selectedApp = app;
        InitializeMesh();
    }

    private void InitializeMesh()
    {
        nodes.Clear();
        edges.Clear();

        // Nexus Hub (Static Center)
        var cp = new Node { 
            Id = "control-plane", 
            Name = "Control Plane", 
            IsControlPlane = true, 
            X = 500, 
            Y = 500, 
            CpuUsage = 5, 
            MemoryUsage = 2.4 
        };
        nodes.Add(cp);

        // Actual Instances
        if (selectedApp != null)
        {
            int count = selectedApp.ActiveReplicas;
            for (int i = 0; i < count; i++)
            {
                double angle = (2 * Math.PI / count) * i;
                int radius = 350;
                int x = 500 + (int)(radius * Math.Cos(angle));
                int y = 500 + (int)(radius * Math.Sin(angle));
                
                var node = new Node { 
                    Id = $"instance-{i}", 
                    Name = $"{selectedApp.Name} Instance {i + 1}", 
                    X = x, 
                    Y = y, 
                    CpuUsage = 0, 
                    MemoryUsage = 0.5 
                };
                nodes.Add(node);
                edges.Add(new Edge { X1 = cp.X, Y1 = cp.Y, X2 = node.X, Y2 = node.Y });
            }
        }
    }

    private void OnMouseDown(MouseEventArgs e, string nodeId)
    {
        draggingNodeId = nodeId;
        var node = nodes.FirstOrDefault(n => n.Id == nodeId);
        if (node != null)
        {
            startX = e.ClientX;
            startY = e.ClientY;
            nodeStartX = node.X;
            nodeStartY = node.Y;
        }
    }

    private void OnMouseMove(MouseEventArgs e)
    {
        if (draggingNodeId != null)
        {
            var node = nodes.FirstOrDefault(n => n.Id == draggingNodeId);
            if (node != null)
            {
                double dx = e.ClientX - startX;
                double dy = e.ClientY - startY;
                node.X = nodeStartX + (int)dx;
                node.Y = nodeStartY + (int)dy;
                UpdateEdges();
            }
        }
    }

    private void OnMouseUp(MouseEventArgs e)
    {
        draggingNodeId = null;
    }

    private void UpdateEdges()
    {
        var cp = nodes.FirstOrDefault(n => n.IsControlPlane);
        if (cp != null)
        {
            edges.Clear();
            foreach (var node in nodes.Where(n => !n.IsControlPlane))
            {
                edges.Add(new Edge { X1 = cp.X, Y1 = cp.Y, X2 = node.X, Y2 = node.Y });
            }
        }
    }

    private void SelectNode(string id)
    {
        selectedNodeId = id;
    }
}

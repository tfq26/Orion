{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Orion",
  "version": "0.1.0",
  "identifier": "com.orion.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Orion",
        "width": 1440,
        "height": 960,
        "minWidth": 1200,
        "minHeight": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "deb",
      "appimage",
      "msi",
      "nsis"
    ],
    "icon": []
  }
}
